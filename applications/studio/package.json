{
  "name": "studio",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "bunx next build",
    "start": "bunx next start",
    "lint": "bunx eslint .",
    "type-check": "bunx tsc --noEmit",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:coverage": "bunx vitest --coverage",
    "test:e2e": "bunx playwright test",
    "db:types": "bunx supabase gen types typescript --project-id <ref> > types/supabase.ts",
    "db:push": "bunx supabase db push",
    "db:reset": "bunx supabase db reset",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "clean": "rm -rf .next"
  },
  "dependencies": {

# ─── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_<key>

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used in sitemap, og:url, canonical links. Must be the production domain.
NEXT_PUBLIC_APP_URL=https://anaqio.com

# ─── Google Analytics ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Optional: Google Tag Manager
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── Brevo (waitlist email automation) ────────────────────────────────────────
BREVO_API_KEY=xkeysib-<key>
# Numeric list ID from Brevo → Contacts → Lists (optional — skipped if unset)
BREVO_LIST_ID=12

# ─── Brand Page ───────────────────────────────────────────────────────────────
# Password protecting /brand route (server action — never exposed to browser)
BRAND_ACCESS_PASSWORD=your_password_here

# ─── Crowdin (dev/CI only) ────────────────────────────────────────────────────
# Only needed to run `bun run export-i18n` for translation sync
CROWDIN_API_TOKEN=<token>
CROWDIN_PROJECT_ID=<project-id>
